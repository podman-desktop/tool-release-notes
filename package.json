{
  "name": "tool-release-notes",
  "version": "1.0.0",
  "description": "Release notes generator for Podman Desktop repository",
  "license": "apache-2.0",
  "scripts": {
    "generate": "tsx ./release-notes/generate-release-notes.ts",
    "test": "vitest --run --passWithNoTests",
    "test:coverage": "pnpm run test --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format:check": "biome format && prettier --cache --check \"release-notes/**/*.ts\"",
    "format:clean": "rimraf node_modules/.cache/prettier",
    "format:fix": "biome format --write && prettier --cache --write \"release-notes/**/*.ts\"",
    "lint:clean": "rimraf .eslintcache",
    "lint:fix": "node --max-old-space-size=8192 node_modules/eslint/bin/eslint.js --cache . --cache-strategy content --fix",
    "lint:check": "node --max-old-space-size=8192 node_modules/eslint/bin/eslint.js --cache . --cache-strategy content",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.7.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@octokit/openapi-types": "^27.0.0",
    "@octokit/rest": "^22.0.1",
    "@types/minimist": "^1.2.5",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.2.1",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-file-progress": "^4.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-redundant-undefined": "^1.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "minimist": "^1.2.8",
    "mustache": "^4.2.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^24",
    "@vitest/coverage-v8": "4.1.5",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "minimist": "^1.2.8",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "form-data@<2.5.4": "2.5.4",
      "lodash@<4.17.12": "4.18.1",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "uuid@<14.0.0": "14.0.0"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,svelte}": [
      "node --max-old-space-size=8192 node_modules/eslint/bin/eslint.js --cache --fix",
      "biome format --write"
    ],
    "*.md": "prettier --cache --write",
    "*.{css,json}": "biome format --write"
  }
}
